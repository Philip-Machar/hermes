	}
}

func TestPickWorker_PrefersLowestLoad(t *testing.T) {
	r := NewRegistry()
	r.Register("busy", "localhost:9001")
	r.Register("idle", "localhost:9002")

	r.UpdateLoad("busy", 10)
	r.UpdateLoad("idle", 0)

	if id := r.PickWorker(); id != "idle" {
