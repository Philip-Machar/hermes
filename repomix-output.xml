      - "${API_HTTP_PORT}:${API_HTTP_PORT}"
      - "${API_GRPC_PORT}:${API_GRPC_PORT}"
    environment:
      RABBITMQ_URL: amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/
