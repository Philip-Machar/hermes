      border-left: 2px solid var(--amber);
      padding: 0.7rem 1.1rem;
      font-size: 0.65rem;
      color: var(--text);
      z-index: 600;
      transform: translateY(6px);
      opacity: 0;
      transition: opacity 0.18s, transform 0.18s;
      pointer-events: none;
      max-width: 300px;
    }
    .toast.show { opacity:1; transform:translateY(0); }
    .toast.err  { border-left-color: var(--red-bright); }
  </style>
</head>
<body>

<div class="shell">
  <header>
    <div class="header-left">
      <div class="wordmark">Her<em>mes</em></div>
      <div class="system-label">Distributed Job Processing System</div>
    </div>
    <div class="header-center">
      <div class="status-pill">
        <div class="pulse-dot" id="sysDot"></div>
        <span id="sysStatus">Connecting</span>
      </div>
      <div class="clock" id="clock">—</div>
    </div>
    <div class="header-right">
      <button class="submit-btn" onclick="openModal()">+ Submit Job</button>
    </div>
  </header>

  <div class="stat-strip">
    <div class="stat-cell">
      <div class="stat-label">Active Workers</div>
      <div class="stat-value" id="sWorkers">—</div>
      <div class="stat-sub">nodes registered</div>
    </div>
    <div class="stat-cell">
      <div class="stat-label">Idle</div>
      <div class="stat-value" id="sIdle">—</div>
      <div class="stat-sub">awaiting work</div>
    </div>
    <div class="stat-cell">
      <div class="stat-label">Busy</div>
      <div class="stat-value amber" id="sBusy">—</div>
      <div class="stat-sub">processing</div>
    </div>
    <div class="stat-cell">
      <div class="stat-label">Jobs This Session</div>
      <div class="stat-value dim" id="sJobs">0</div>
      <div class="stat-sub">submitted via dashboard</div>
    </div>
  </div>

  <div class="content">
    <div class="workers-panel">
      <div class="section-head">Worker Fleet</div>
      <div id="workersList"><div class="empty-state">Polling for workers…</div></div>
    </div>

    <div class="log-panel">
      <div class="section-head plain">Activity Log</div>
      <div class="log-body" id="logBody">
        <div class="empty-state">Waiting for events…</div>
      </div>
    </div>
  </div>

  <footer>
    <div class="footer-txt">Hermes v1.0 — Philip Machar</div>
    <div class="footer-txt" id="lastPoll">Last poll: —</div>
  </footer>
</div>

<!-- Modal -->
<div class="backdrop" id="backdrop">
  <div class="modal">
    <div class="modal-title">Submit <em>Job</em></div>
    <div class="field">
      <label>Job Type</label>
      <select id="jobType">
        <option value="email">email</option>
        <option value="resize-image">resize-image</option>
      </select>
    </div>
    <div class="field">
      <label>Payload (JSON)</label>
      <textarea id="jobPayload" rows="5" placeholder='{"to":"user@example.com","subject":"Hello"}'></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn btn-submit" onclick="submitJob()">Dispatch</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  // ── Constants ──────────────────────────────────────────────────────────────
  const POLL_MS   = 3000;
  const LOG_MAX   = 80;

  // ── State ──────────────────────────────────────────────────────────────────
  let sessionJobs    = 0;
  let seenEventIDs   = new Set();   // deduplicate events from /events endpoint
  let barStart       = null;

  // ── Clock ──────────────────────────────────────────────────────────────────
  function tickClock() {
    document.getElementById('clock').textContent =
      new Date().toUTCString().replace('GMT','UTC');
  }
  tickClock();
  setInterval(tickClock, 1000);

  // ── Poll /workers ──────────────────────────────────────────────────────────
  async function pollWorkers() {
    try {
      const res  = await fetch('/workers');
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      renderWorkers(data);
      setStatus(data.count > 0);
    } catch(e) {
      setStatus(false);
    }
  }

  function renderWorkers(data) {
    const workers = data.workers || [];
    const idle    = workers.filter(w => w.status === 'idle').length;
    const busy    = workers.filter(w => w.status === 'busy').length;

    document.getElementById('sWorkers').textContent = data.count ?? 0;
    document.getElementById('sIdle').textContent    = idle;
    document.getElementById('sBusy').textContent    = busy;

    const list = document.getElementById('workersList');
    if (!workers.length) {
      list.innerHTML = '<div class="empty-state">No workers registered.</div>';
      return;
    }

    list.innerHTML = workers.map((w, i) => {
      const loadPct = Math.min(w.load * 20, 100);
      const short   = w.worker_id.length > 20
        ? w.worker_id.slice(0,8) + '…' + w.worker_id.slice(-6)
        : w.worker_id;
      return `
        <div class="worker-row" style="animation-delay:${i*0.04}s">
          <div class="w-dot ${w.status}"></div>
          <div class="w-id">${short}<span>${w.status}</span></div>
          <div class="w-status">${w.status}</div>
          <div class="w-bar-wrap"><div class="w-bar" style="width:${loadPct}%"></div></div>
          <div class="w-seen">${timeSince(w.last_seen_unix)}</div>
        </div>`;
    }).join('');
  }

  function setStatus(online) {
    const dot  = document.getElementById('sysDot');
    const txt  = document.getElementById('sysStatus');
    dot.style.background = online ? 'var(--green)' : 'var(--amber)';
    txt.textContent      = online ? 'Operational' : 'No workers';
  }

  // ── Poll /events ───────────────────────────────────────────────────────────
  async function pollEvents() {
    try {
      const res  = await fetch('/events');
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      renderEvents(data.events || []);
      document.getElementById('lastPoll').textContent =
        'Last poll: ' + new Date().toLocaleTimeString();
    } catch(e) { /* silent */ }
  }

  function renderEvents(evts) {
    const body = document.getElementById('logBody');
    let hasNew = false;

    // evts arrive newest-first from the server; process in that order
    // so we prepend them in order.
    for (const e of evts) {
      // Use time+jobID as a stable dedup key.
      const key = e.time + '|' + e.job_id;
      if (seenEventIDs.has(key)) continue;
      seenEventIDs.add(key);
      hasNew = true;

      const t    = new Date(e.time);
      const hms  = t.toLocaleTimeString('en-GB', { hour12: false });
      const div  = document.createElement('div');
      div.className = 'log-entry';
      div.innerHTML = `
        <div class="log-time">${hms}</div>
        <div class="log-content">
          <div class="log-type ${e.kind}">${e.kind}</div>
          <div class="log-detail">${e.job_type} · ${e.job_id.slice(0,8)}… · ${e.message}</div>
        </div>`;

      // Remove placeholder if present.
      const placeholder = body.querySelector('.empty-state');
      if (placeholder) placeholder.remove();

      body.prepend(div);
    }

    // Trim to max.
    while (body.children.length > LOG_MAX) body.removeChild(body.lastChild);

    // Keep seenEventIDs from growing unbounded.
    if (seenEventIDs.size > 500) seenEventIDs.clear();
  }

  // ── Combined poll ──────────────────────────────────────────────────────────
  async function poll() {
    await Promise.all([pollWorkers(), pollEvents()]);
  }

  // ── Submit job ─────────────────────────────────────────────────────────────
  function openModal()  { document.getElementById('backdrop').classList.add('open'); }
  function closeModal() { document.getElementById('backdrop').classList.remove('open'); }

  document.getElementById('backdrop').addEventListener('click', e => {
    if (e.target === document.getElementById('backdrop')) closeModal();
  });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  async function submitJob() {
    const type   = document.getElementById('jobType').value;
    const rawPay = document.getElementById('jobPayload').value.trim();
    let payload;
    try { payload = rawPay ? JSON.parse(rawPay) : {}; }
    catch { showToast('Invalid JSON payload', true); return; }

    try {
      const res = await fetch('/jobs', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, payload }),
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();

      sessionJobs++;
      document.getElementById('sJobs').textContent = sessionJobs;

      showToast('Job dispatched — ' + data.routed);
      closeModal();
      // Immediate poll so the new event appears right away.
      setTimeout(poll, 200);
    } catch(e) {
      showToast('Dispatch failed: ' + e.message, true);
    }
  }

  // ── Toast ──────────────────────────────────────────────────────────────────
  let toastTimer;
  function showToast(msg, err = false) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className   = 'toast show' + (err ? ' err' : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => { t.className = 'toast'; }, 3000);
  }

  // ── Helpers ────────────────────────────────────────────────────────────────
  function timeSince(unix) {
    const d = Math.floor(Date.now()/1000) - unix;
    if (d < 5)  return 'just now';
    if (d < 60) return d + 's ago';
    return Math.floor(d/60) + 'm ago';
  }

  // ── Init ───────────────────────────────────────────────────────────────────
  poll();
  setInterval(poll, POLL_MS);
</script>
</body>
</html>
