# RabbitMQ credentials
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASS=your_rabbitmq_password
RABBITMQ_URL=amqp://your_rabbitmq_user:your_rabbitmq_password@localhost:5672/
RABBITMQ_QUEUE=jobs
RABBITMQ_DLQ=jobs.dlq

# API Server
API_HTTP_PORT=8081
API_GRPC_PORT=50051

# Worker
# Use localhost when running locally, api when running via Docker
API_GRPC_ADDR=localhost:50051
DOCKER_API_GRPC_ADDR=api:50051
WORKER_DISPATCH_PORT=9001